{
  "name": "sains-masemba-platform-v16",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "turbo dev --continue",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:super-admin": "npm run dev -w @sh/super-admin",
    "dev:guru": "npm run dev -w @sh/guru",
    "dev:siswa": "npm run dev -w @sh/siswa",
    "dev:orang-tua": "npm run dev -w @sh/orang-tua",
    "db:generate": "npm exec -w @sh/db prisma generate --",
    "db:push": "npm exec -w @sh/db prisma db push --",
    "db:studio": "npm exec -w @sh/db prisma studio --",
    "db:seed": "npm run seed -w @sh/db",
    "build:siswa": "npm run db:generate && npm run build -w @sh/siswa",
    "build:guru": "npm run db:generate && npm run build -w @sh/guru",
    "build:super-admin": "npm run db:generate && npm run build -w @sh/super-admin",
    "build:orang-tua": "npm run db:generate && npm run build -w @sh/orang-tua",
    "vercel:siswa": "npm run build:siswa",
    "vercel:guru": "npm run build:guru",
    "vercel:super-admin": "npm run build:super-admin",
    "vercel:orang-tua": "npm run build:orang-tua",
    "vercel:install": "npm ci --ignore-scripts --no-audit --no-fund"
  },
  "devDependencies": {
    "turbo": "^2.10.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
