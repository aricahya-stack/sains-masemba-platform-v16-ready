generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  GURU
  SISWA
  ORANG_TUA
}

enum PublishStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum TryoutStatus {
  DRAFT
  SCHEDULED
  OPEN
  PAUSED
  ENDED
  ARCHIVED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum ScoringMode {
  EXACT_MATCH
  PARTIAL_NO_PENALTY
}

model User {
  id             String              @id @default(cuid())
  fullName       String
  email          String              @unique
  passwordHash   String?
  role           UserRole
  phone          String?
  className      String?
  status         String              @default("ACTIVE")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  materials      Material[]          @relation("MaterialAuthor")
  tkadTips       TkadTip[]           @relation("TkadTipAuthor")
  questions      Question[]          @relation("QuestionAuthor")
  tryouts        Tryout[]            @relation("TryoutAuthor")
  attempts       Attempt[]
  practiceAttempts PracticeAttempt[]
  parentChildren ParentStudentLink[] @relation("ParentUser")
  childParents   ParentStudentLink[] @relation("StudentUser")

  @@index([role, status])
  @@index([createdAt])
}

model ParentStudentLink {
  id           String   @id @default(cuid())
  parentId     String
  studentId    String
  relationType String   @default("Wali")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  parent       User     @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  student      User     @relation("StudentUser", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId, isActive])
  @@index([studentId, isActive])
}


model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Topic {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  subject     String      @default("IPA SMP")
  description String?
  orderNo     Int         @default(0)
  materials   Material[]
  blueprints  Blueprint[]
  questions   Question[]
  practiceAttempts PracticeAttempt[]
}

model Material {
  id            String        @id @default(cuid())
  topicId       String
  authorId      String
  title         String
  summaryText   String?
  summaryHtml   String?
  coverImageUrl String?
  level         String?
  status        PublishStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  topic         Topic         @relation(fields: [topicId], references: [id])
  author        User          @relation("MaterialAuthor", fields: [authorId], references: [id])
  sections      MaterialSection[]
  objectives    LearningObjective[]

  @@index([topicId, status])
  @@index([authorId, status])
  @@index([status, updatedAt])
}

model MaterialSection {
  id          String   @id @default(cuid())
  materialId  String
  orderNo     Int
  title       String
  contentText String?
  contentHtml String?
  imageUrl    String?
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model LearningObjective {
  id         String   @id @default(cuid())
  materialId String
  orderNo    Int
  objective  String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model TkadTip {
  id          String        @id @default(cuid())
  authorId    String
  category    String
  title       String
  contentHtml String
  orderNo     Int           @default(0)
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      User          @relation("TkadTipAuthor", fields: [authorId], references: [id])

  @@index([status, orderNo])
  @@index([authorId, status])
}

model Blueprint {
  id                  String   @id @default(cuid())
  code                String   @unique
  periodCode          String?
  periodName          String?
  testGroup           String?
  topicId             String?
  competency          String
  indicator           String
  materialName        String?
  blueprintText       String?
  labelRahasia        String?
  cognitiveLevel      String?
  targetDifficulty    String?
  targetQuestionCount Int      @default(0)
  topic               Topic?   @relation(fields: [topicId], references: [id])
  questions           Question[]

  @@index([topicId])
  @@index([periodCode])
  @@index([testGroup])
}

model Question {
  id              String          @id @default(cuid())
  code            String          @unique
  topicId         String
  blueprintId     String?
  authorId        String
  stimulusOrder   Int             @default(1)
  questionType    QuestionType    @default(SINGLE_CHOICE)
  scoringMode     ScoringMode     @default(EXACT_MATCH)
  maxScore        Float           @default(1)
  questionText    String
  questionHtml    String?
  explanation     String?
  difficulty      String?
  status          PublishStatus   @default(DRAFT)
  topic           Topic           @relation(fields: [topicId], references: [id])
  blueprint       Blueprint?      @relation(fields: [blueprintId], references: [id])
  author          User            @relation("QuestionAuthor", fields: [authorId], references: [id])
  options         QuestionOption[]
  tryoutQuestions TryoutQuestion[]
  attemptAnswers  AttemptAnswer[]
  practiceAnswers PracticeAnswer[]

  @@index([topicId, status])
  @@index([authorId, status])
  @@index([blueprintId])
}

model QuestionOption {
  id         String          @id @default(cuid())
  questionId String
  label      String
  optionText String
  isCorrect  Boolean         @default(false)
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    AttemptAnswer[]

  @@index([questionId])
}

model Tryout {
  id              String         @id @default(cuid())
  authorId        String
  title           String
  description     String?
  durationMinutes Int            @default(60)
  status          TryoutStatus   @default(DRAFT)
  startAt         DateTime?
  endAt           DateTime?
  rulesHtml       String?
  author          User           @relation("TryoutAuthor", fields: [authorId], references: [id])
  questions       TryoutQuestion[]
  attempts        Attempt[]
  incidents       TryoutIncident[]

  @@index([status, startAt, endAt])
  @@index([authorId, status])
}

model TryoutQuestion {
  id         String   @id @default(cuid())
  tryoutId   String
  questionId String
  orderNo    Int
  tryout     Tryout   @relation(fields: [tryoutId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([tryoutId, questionId])
  @@index([questionId])
}

model Attempt {
  id           String          @id @default(cuid())
  userId       String
  tryoutId     String
  score        Float           @default(0)
  warnings     Int             @default(0)
  startedAt    DateTime        @default(now())
  submittedAt  DateTime?
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryout       Tryout          @relation(fields: [tryoutId], references: [id], onDelete: Cascade)
  answers      AttemptAnswer[]
  incidents    TryoutIncident[]

  @@index([userId, startedAt])
  @@index([tryoutId, submittedAt])
  @@index([userId, tryoutId, submittedAt])
}

model AttemptAnswer {
  id               String         @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  selectedOptionIds String[]       @default([])
  trueFalseAnswers Json?
  score            Float          @default(0)
  isCorrect        Boolean        @default(false)
  answeredAt       DateTime       @default(now())
  attempt          Attempt        @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
}


model PracticeAttempt {
  id          String           @id @default(cuid())
  userId      String
  topicId     String
  score       Float            @default(0)
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  answers     PracticeAnswer[]

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}

model PracticeAnswer {
  id                String          @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionId  String?
  selectedOptionIds String[]        @default([])
  trueFalseAnswers  Json?
  score             Float           @default(0)
  isCorrect         Boolean         @default(false)
  isAnswered        Boolean         @default(false)
  answeredAt        DateTime        @default(now())
  attempt           PracticeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question          Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model TryoutIncident {
  id         String   @id @default(cuid())
  tryoutId   String
  attemptId  String?
  userId     String?
  type       String
  message    String?
  createdAt  DateTime @default(now())
  tryout     Tryout   @relation(fields: [tryoutId], references: [id], onDelete: Cascade)
  attempt    Attempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([tryoutId, createdAt])
  @@index([attemptId])
  @@index([userId, createdAt])
}
